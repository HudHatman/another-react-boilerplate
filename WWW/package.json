{
    "name": "another-react-boilerplate",
    "private": true,
    "scripts": {
        "build": "npm run clean-dist && webpack --config=configs/webpack/prod && cp ../API/public/.htaccess ../dist/ && cp ../API/public/favicon.ico ../dist/",
        "build:dev": "npm run clean-dist && webpack --config=configs/webpack/dev && cp ../API/public/.htaccess ../dist/ && cp ../API/public/favicon.ico ../dist/",
        "clean-dist": "rm -f -r -d ../dist/js/* && rm -f -r -d ../dist/fonts/* && rm -f -r -d ../dist/build/*",
        "prettier-write": "prettier --write \"{src,tests}/**/*.{js,jsx,css,scss,ts,tsx}\"",
        "prettier-check": "prettier --list-different \"{src,tests}/**/*.{js,jsx,css,scss,ts,tsx}\"",
        "start": "npm run start-dev",
        "start-dev": "webpack serve --config=configs/webpack/dev.js"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/polyfill": "^7.12.1",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.7.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-redux": "^7.1.34",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.59.3",
        "babel-loader": "^10.1.1",
        "css-loader": "^7.1.4",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "express": "^5.2.1",
        "html-webpack-plugin": "^5.6.7",
        "image-webpack-loader": "^8.1.0",
        "jest": "^30.4.2",
        "sass": "^1.99.0",
        "prettier": "^3.8.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "rimraf": "^6.1.3",
        "sass-loader": "^16.0.8",
        "style-loader": "^4.0.0",
        "typescript": "^6.0.3",
        "url": "^0.11.4",
        "webpack": "^5.106.2",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.2.4",
        "webpack-merge": "^6.0.1"
    },
    "dependencies": {
        "axios": "^1.16.0",
        "bootstrap": "^5.3.8",
        "classnames": "^2.5.1",
        "copy-to-clipboard": "^4.0.2",
        "create-react-class": "^15.7.0",
        "jquery": "^4.0.0",
        "laravel-echo": "^2.3.4",
        "localstoragedb": "^2.3.2",
        "lodash": "^4.18.1",
        "md5": "^2.3.0",
        "moment": "^2.30.1",
        "pusher-js": "^8.5.0",
        "react-custom-scrollbars": "^4.2.1",
        "react-icons": "^5.6.0",
        "react-redux": "^9.2.0",
        "react-router": "^7.15.0",
        "react-router-dom": "^7.15.0",
        "react-transition-group": "^4.4.5",
        "redux-form": "^8.3.10",
        "redux-thunk": "^3.1.0",
        "roboto-fontface": "^0.10.0",
        "typeface-spectral": "^1.1.13"
    },
    "types": "./src/types.d.tsx"
}
